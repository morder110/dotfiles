# application/x-gz-font-linux-psf

# --- Osu ---
application/x-osu-beatmap-archive=sh.ppy.osu.desktop
application/x-osu-skin-archive=sh.ppy.osu.desktop
application/x-osu-replay=sh.ppy.osu.desktop
application/x-osu-beatmap=sh.ppy.osu.desktop
application/x-osu-storyboard=sh.ppy.osu.desktop

# --- Muse dash ---
application/x-mdm-package=muse-dash-chart-installer.desktop

# --- Other ---
x-scheme-handler/discord=vesktop.desktop
application/octet-stream=bless.desktop
x-scheme-handler/jetbrains=jetbrains-toolbox.desktop
x-scheme-handler/ror2mm=r2modman.desktop

# ------------------------------------------------

[Added Associations]
# --- Web Browser ---
text/html=waterfox.desktop

x-scheme-handler/http=chromium.desktop
x-scheme-handler/https=chromium.desktop
x-scheme-handler/about=chromium.desktop
x-scheme-handler/unknown=chromium.desktop
text/html=chromium.desktop

# --- Other ---
application/octet-stream=bless.desktop;

# Don't know how this works
image/x-xcf=yazi.desktop;
image/*=com.github.PintaProject.Pinta.desktop
image/*=gimp.desktop
image/*=waterfox.desktop

text/markdown=obsidian.desktop
